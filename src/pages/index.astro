---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { AUTHOR_NAME, AUTHOR_SUMMARY, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featuredPost, ...archivePosts] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.landing {
				padding: 2rem 0 4rem;
			}

			.hero {
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--color-line);
				margin-bottom: 2rem;
			}

			.hero-copy h1 {
				max-width: 13ch;
				margin-bottom: 1rem;
			}

			.hero-notes {
				display: grid;
				gap: 0.85rem;
				margin-top: 1.5rem;
			}

			.note-list {
				display: grid;
				gap: 0.9rem;
			}

			.note-item strong {
				display: block;
				font-family: var(--font-display);
				font-size: 1.05rem;
				margin-bottom: 0.2rem;
			}

			.note-item p,
			.section-intro,
			.archive-copy {
				margin: 0;
				color: var(--color-ink-soft);
			}

			.featured {
				margin-bottom: 2rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--color-line);
			}

			.featured-card {
				display: grid;
				gap: 1rem;
				text-decoration: none;
			}

			.featured-copy {
				display: grid;
				gap: 0.8rem;
				align-content: start;
			}

			.featured-copy h2,
			.post-card h3 {
				margin: 0;
			}

			.featured-image,
			.post-card img {
				overflow: hidden;
			}

			.archive-panel {
				margin-top: 1.2rem;
			}

			.post-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0;
			}

			.post-card {
				display: grid;
				gap: 0.9rem;
				padding: 1.4rem 0;
				border-top: 1px solid var(--color-line);
				text-decoration: none;
			}

			.post-card .meta-row {
				font-size: 0.84rem;
			}

			.post-card p {
				margin: 0;
				color: var(--color-ink-soft);
			}

			.post-card:hover h3,
			.featured-card:hover h2 {
				color: var(--color-accent-strong);
			}

			@media (max-width: 720px) {
				.landing {
					padding-top: 1.2rem;
				}

				.hero {
					margin-bottom: 1.5rem;
					padding-bottom: 1.5rem;
				}

				.featured {
					margin-bottom: 1.5rem;
					padding-bottom: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="landing">
			<div class="page-shell">
				<section class="hero">
					<div class="hero-copy">
						<p class="eyebrow">{AUTHOR_NAME}</p>
						<h1>Systems writing with an operator&rsquo;s bias.</h1>
						<p class="lede">
							{SITE_DESCRIPTION} Essays here stay practical: real failure modes, production
							habits, and the tradeoffs behind good technical decisions.
						</p>
						<div class="button-row">
							<a class="button-link primary" href="#latest">Read the latest</a>
							<a class="button-link" href="/about">About Steve</a>
						</div>
					</div>
					<aside class="hero-notes">
						<p class="eyebrow">What you&rsquo;ll find</p>
						<div class="note-list">
							<div class="note-item">
								<strong>Operations and networking</strong>
								<p>Routing, interop, outages, and the details that make production messy.</p>
							</div>
							<div class="note-item">
								<strong>Security and automation</strong>
								<p>Defensive engineering, repeatable workflows, and pragmatic tooling.</p>
							</div>
							<div class="note-item">
								<strong>AI and systems thinking</strong>
								<p>{AUTHOR_SUMMARY}.</p>
							</div>
						</div>
					</aside>
				</section>

				{
					featuredPost && (
						<section class="featured">
							<a class="featured-card" href={`/blog/${featuredPost.id}/`}>
								<div class="featured-copy">
									<p class="eyebrow">Latest essay</p>
									<h2>{featuredPost.data.title}</h2>
									<p class="section-intro">{featuredPost.data.description}</p>
									<div class="meta-row">
										<span>
											<FormattedDate date={featuredPost.data.pubDate} />
										</span>
										<span>Full article</span>
									</div>
								</div>
								{featuredPost.data.heroImage && (
									<div class="featured-image">
										<Image
											width={960}
											height={640}
											src={featuredPost.data.heroImage}
											alt=""
										/>
									</div>
								)}
							</a>
							<div class="archive-panel surface-panel">
								<p class="eyebrow">Editorial note</p>
								<p class="archive-copy">
									This site favors durable technical writing over feed churn. If a post is here,
									it is meant to be useful after the hype cycle ends.
								</p>
							</div>
						</section>
					)
				}

				<section id="latest">
					<p class="eyebrow">Archive</p>
					<div class="post-grid">
						{
							archivePosts.map((post) => (
								<a class="post-card" href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={420} src={post.data.heroImage} alt="" />
									)}
									<div class="meta-row">
										<span>
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</a>
							))
						}
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
