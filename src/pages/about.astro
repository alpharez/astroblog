---
import { AUTHOR_NAME, AUTHOR_SUMMARY, SITE_TITLE, SOCIAL_LINKS } from '../consts';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const { github, linkedin } = SOCIAL_LINKS;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={`About ${AUTHOR_NAME}`} />
		<style>
			.about-page {
				padding: 2rem 0 4rem;
			}

			.about-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 2rem;
			}

			.about-panel,
			.about-sidebar {
				padding: 0;
			}

			.about-panel p + p {
				margin-top: 1rem;
			}

			.about-sidebar {
				display: grid;
				gap: 1rem;
				align-content: start;
				padding-top: 1.4rem;
				border-top: 1px solid var(--color-line);
			}

			.focus-list {
				margin: 0;
				padding-left: 1.1rem;
			}

			.focus-list li + li {
				margin-top: 0.65rem;
			}

			@media (max-width: 720px) {
				.about-page {
					padding-top: 1.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="about-page">
			<div class="page-shell">
				<section class="about-grid">
					<div class="about-panel surface-panel">
						<p class="eyebrow">About</p>
						<h1>{AUTHOR_NAME}</h1>
						<p class="lede">
							I write about infrastructure, security, automation, and AI from the point of
							view of someone who has to make systems behave under real constraints.
						</p>
						<p>
							My work sits at the intersection of network engineering, operational discipline,
							and technical communication. I care about designs that survive contact with
							production, not just slides or theory.
						</p>
						<p>
							This site is where I turn incidents, edge cases, experiments, and design choices
							into durable notes that other operators can use. The goal is clarity, not noise.
						</p>
						<div class="button-row">
							<a class="button-link primary" href={github} target="_blank" rel="noreferrer">
								GitHub
							</a>
							<a class="button-link" href={linkedin} target="_blank" rel="noreferrer">
								LinkedIn
							</a>
						</div>
					</div>

					<aside class="about-sidebar surface-panel">
						<p class="eyebrow">Focus</p>
						<p class="lede">{AUTHOR_SUMMARY}.</p>
						<ul class="focus-list">
							<li>Production networking and interoperability problems</li>
							<li>Security analysis grounded in implementation details</li>
							<li>Automation that removes toil without hiding complexity</li>
							<li>AI workflows that are actually useful to technical teams</li>
						</ul>
					</aside>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
