---
import { AUTHOR_SUMMARY, SITE_TITLE, SOCIAL_LINKS } from '../consts';
import HeaderLink from './HeaderLink.astro';

const { github, linkedin } = SOCIAL_LINKS;
---

<header class="site-header">
	<div class="page-shell">
		<nav>
			<a class="brand" href="/">
				<span class="brand-mark">{SITE_TITLE}</span>
				<span class="brand-summary">{AUTHOR_SUMMARY}</span>
			</a>
			<div class="internal-links">
				<HeaderLink href="/">Journal</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			<div class="social-links" aria-label="Social links">
				<a class="pill" href={github} target="_blank" rel="noreferrer">GitHub</a>
				<a class="pill" href={linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
			</div>
		</nav>
	</div>
</header>

<style>
	.site-header {
		padding: 1.1rem 0 0;
		border-bottom: 1px solid var(--color-line);
	}

	nav {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto auto;
		align-items: center;
		gap: 1rem;
		padding: 0 0 1rem;
	}

	.brand {
		display: grid;
		gap: 0.12rem;
		min-width: 0;
		text-decoration: none;
	}

	.brand-mark {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.brand-summary {
		font-size: 0.82rem;
		color: var(--color-ink-soft);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.internal-links a {
		color: var(--color-ink-soft);
	}

	.internal-links a.active {
		color: var(--color-accent-strong);
	}

	.social-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		justify-content: flex-end;
	}

	@media (max-width: 920px) {
		nav {
			grid-template-columns: 1fr;
		}

		.social-links {
			justify-content: flex-start;
		}
	}

	@media (max-width: 520px) {
		.site-header {
			padding-top: 0.75rem;
		}

		.brand-summary {
			white-space: normal;
		}
	}
</style>
