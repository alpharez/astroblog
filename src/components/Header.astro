---
import { AUTHOR_SUMMARY, SITE_TITLE, SOCIAL_LINKS } from '../consts';
import HeaderLink from './HeaderLink.astro';

const { github, linkedin } = SOCIAL_LINKS;
---

<header class="site-header">
	<div class="page-shell">
		<nav>
			<a class="brand" href="/">
				<span class="brand-mark">{SITE_TITLE}</span>
				<span class="brand-summary">{AUTHOR_SUMMARY}</span>
			</a>
			<div class="internal-links">
				<HeaderLink href="/">Journal</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			<div class="social-links" aria-label="Social links">
				<a class="pill" href={github} target="_blank" rel="noreferrer">GitHub</a>
				<a class="pill" href={linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
			</div>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 1rem 0 0;
	}

	nav {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) auto auto;
		align-items: center;
		gap: 1rem;
		padding: 1rem 1.15rem;
		border: 1px solid rgba(20, 25, 34, 0.08);
		border-radius: 999px;
		background: rgba(255, 249, 242, 0.78);
		backdrop-filter: blur(20px);
		box-shadow: 0 18px 40px rgba(31, 25, 19, 0.08);
	}

	.brand {
		display: grid;
		gap: 0.12rem;
		min-width: 0;
		text-decoration: none;
	}

	.brand-mark {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.brand-summary {
		font-size: 0.82rem;
		color: var(--color-ink-soft);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem;
		padding: 0.25rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.55);
	}

	.internal-links a {
		padding: 0.58rem 0.95rem;
		border-radius: 999px;
		color: var(--color-ink-soft);
	}

	.internal-links a.active {
		background: rgba(158, 61, 40, 0.12);
		color: var(--color-accent-strong);
	}

	.social-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		justify-content: flex-end;
	}

	@media (max-width: 920px) {
		nav {
			grid-template-columns: 1fr;
			border-radius: 1.4rem;
		}

		.social-links {
			justify-content: flex-start;
		}
	}

	@media (max-width: 520px) {
		.site-header {
			padding-top: 0.65rem;
		}

		nav {
			padding: 0.9rem;
		}

		.brand-summary {
			white-space: normal;
		}
	}
</style>
