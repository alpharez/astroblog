---
import { AUTHOR_NAME, SOCIAL_LINKS } from '../consts';

const { github, linkedin } = SOCIAL_LINKS;
const today = new Date();
---

<footer>
	<div class="page-shell">
		<div class="footer-card">
			<div>
				<p class="eyebrow">Steveclement.me</p>
				<p class="footer-copy">
					Field notes on systems, operators, failure modes, and the tooling required to keep
					things working.
				</p>
			</div>
			<div class="footer-links">
				<a class="pill" href={github} target="_blank" rel="noreferrer">GitHub</a>
				<a class="pill" href={linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
				<a class="pill" href="/rss.xml">RSS</a>
			</div>
			<p class="copyright">&copy; {today.getFullYear()} {AUTHOR_NAME}</p>
		</div>
	</div>
</footer>

<style>
	.footer-card {
		display: grid;
		gap: 1.2rem;
		padding: 1.4rem;
		border: 1px solid rgba(20, 25, 34, 0.08);
		border-radius: 1.6rem;
		background: rgba(255, 250, 243, 0.7);
		box-shadow: 0 18px 36px rgba(31, 25, 19, 0.08);
	}

	.footer-copy,
	.copyright {
		margin: 0;
		color: var(--color-ink-soft);
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
	}
</style>
